.mixer-strip {
  display: grid;
  grid-template-rows: auto 1fr auto 36px auto auto;
  justify-items: center;
  gap: 5px;
  min-width: 44px;
}

.mixer-volume-number {
  width: 52px;
  min-height: 28px;
  border: 2px solid var(--pink);
  background: var(--white);
  color: var(--pink);
}

.mixer-strip input[type="range"] {
  writing-mode: vertical-lr;
  direction: rtl;
}

.mixer-strip meter {
  width: 12px;
  height: 34px;
}

.mixer-strip button {
  min-width: 34px;
  min-height: 26px;
  padding: 0;
}

.clip-context-menu {
  position: fixed;
  z-index: 30;
  display: grid;
  gap: 4px;
  width: 150px;
  border: 3px solid var(--pink);
  background: var(--white);
  box-shadow: 5px 5px 0 var(--pink);
  padding: 6px;
}

.clip-property-panel {
  display: grid;
  grid-template-columns: minmax(0, 1.2fr) repeat(4, minmax(90px, 1fr));
  gap: 8px;
  align-items: center;
  border: 2px solid var(--pink);
  padding: 8px;
  text-transform: uppercase;
}

.clip-property-panel span {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.clip-property-panel label {
  display: grid;
  gap: 3px;
  font-size: 11px;
}

.clip-property-panel input[type="number"] {
  min-width: 0;
  width: 100%;
  border: 2px solid var(--pink);
  color: var(--pink);
}

.checkbox-row {
  display: flex;
  gap: 8px;
  align-items: center;
  text-transform: uppercase;
}

.export-progress {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 140px 44px;
  gap: 8px;
  align-items: center;
  border: 2px solid var(--pink);
  padding: 8px;
  text-transform: uppercase;
}

.export-progress progress {
  width: 100%;
  accent-color: var(--active-pink);
}

.export-advanced-controls {
  display: grid;
  grid-template-columns: repeat(2, minmax(140px, 1fr));
  gap: 8px;
}

.export-advanced-controls label {
  display: grid;
  gap: 4px;
  font-size: 11px;
  text-transform: uppercase;
}

.export-advanced-controls input,
.export-advanced-controls select {
  min-width: 0;
  min-height: 32px;
  border: 2px solid var(--pink);
  background: var(--white);
  color: var(--pink);
}

.export-preview-window {
  display: grid;
  grid-template-columns: 160px minmax(0, 1fr);
  gap: 10px;
  align-items: center;
  border: 2px solid var(--pink);
  padding: 8px;
  text-transform: uppercase;
}

.export-preview-window canvas {
  width: 160px;
  max-height: 120px;
  border: 2px solid var(--pink);
  image-rendering: crisp-edges;
  image-rendering: pixelated;
  object-fit: contain;
}

.panel {
  display: flex;
  flex-direction: column;
  gap: 14px;
  padding: 12px;
  min-height: 0;
  overflow: hidden;
}

.brand {
  border: 2px solid var(--pink);
  padding: 10px;
  text-transform: uppercase;
}

.brand span,
.brand strong {
  display: block;
}

.brand strong {
  color: var(--pink);
  font-size: 24px;
  line-height: 0.95;
}

.control-group {
  display: grid;
  gap: 8px;
  min-width: 0;
}

.control-group h2 {
  margin: 0;
  border-bottom: 3px solid var(--pink);
  color: var(--pink);
  font-size: 13px;
  text-transform: uppercase;
}

.button-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 8px;
}

.tool-settings-panel {
  border: 2px solid var(--pink);
  padding: 10px;
}

.tool-preview-shell {
  border: 2px solid var(--pink);
  background: var(--white);
  padding: 6px;
}

.tool-preview-canvas {
  display: block;
  width: 100%;
  height: auto;
  image-rendering: crisp-edges;
  image-rendering: pixelated;
}

.tool-settings-grid {
  display: grid;
  gap: 8px;
}

.tool-settings-grid label {
  display: grid;
  gap: 4px;
  text-transform: uppercase;
}

.tool-settings-grid input[type="range"],
.tool-settings-grid select {
  width: 100%;
  min-height: 30px;
  border: 2px solid var(--pink);
  background: var(--white);
  color: var(--pink);
}

.tool-color-readout {
  margin: 0;
  border: 2px solid var(--pink);
  padding: 8px;
  text-transform: uppercase;
}

.tool-color-readout strong {
  color: var(--active-pink);
}

.shape-step-feedback {
  margin: 0;
  border: 2px solid var(--active-pink);
  padding: 8px;
  background: var(--white);
  color: var(--active-pink);
  text-transform: uppercase;
}

.status-readout {
  margin: 0;
  border: 2px solid var(--pink);
  padding: 8px;
  color: var(--pink);
  font-size: 12px;
  text-transform: uppercase;
  overflow: hidden;
  text-overflow: ellipsis;
}

.palette {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;
}

.palette-six {
  grid-template-columns: repeat(3, 1fr);
}

.swatch {
  aspect-ratio: 1;
  min-height: 0;
  outline: 0 solid var(--pink);
}

.active-swatch {
  outline: 2px solid var(--active-pink);
  outline-offset: 2px;
}

.stage-card {
  display: grid;
  align-self: stretch;
  justify-self: stretch;
  min-width: 0;
  min-height: 0;
  overflow: hidden;
  padding: 10px;
}

.depth-layer-tabs {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 5px;
}

.drawing-canvas {
  display: block;
  border: 3px solid var(--pink);
  background: var(--white);
  cursor: crosshair;
  touch-action: none;
  width: 100%;
  height: 100%;
  min-width: 0;
  min-height: 0;
  image-rendering: crisp-edges;
  image-rendering: pixelated;
}

.layers {
  display: grid;
  gap: 8px;
}

.layer {
  display: grid;
  grid-template-columns: 34px 64px 1fr;
  gap: 6px;
  align-items: center;
  border: 2px solid var(--pink);
  padding: 6px;
  min-width: 0;
}

.active-layer {
  border-color: var(--active-pink);
  box-shadow: 3px 3px 0 var(--active-pink);
}

.layer label {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
  font-size: 11px;
  text-transform: uppercase;
}

.layer-name-button {
  min-width: 0;
  min-height: 28px;
  padding: 0;
}

.layer-color-pickers {
  display: flex;
  justify-content: flex-end;
  gap: 6px;
  min-width: 0;
}

.layer-color-row {
  position: relative;
  display: block;
}

.layer-color-chip {
  position: relative;
  width: 32px;
  min-height: 32px;
  border-width: 2px;
  color: transparent;
  overflow: visible;
  text-align: center;
}

.layer-color-chip::before {
  content: "";
  position: absolute;
  inset: 3px auto 3px -7px;
  width: 6px;
  background: var(--active-pink);
  opacity: 0;
}

.layer-color-chip span {
  position: absolute;
  width: 1px;
  height: 1px;
  overflow: hidden;
  clip: rect(0 0 0 0);
  white-space: nowrap;
}

.layer-color-chip:hover::before,
.active-layer-color-chip::before {
  opacity: 1;
}

.active-layer-color-chip {
  border-color: var(--active-pink);
  outline: 2px solid var(--active-pink);
  outline-offset: 2px;
}

.background-color-row {
  position: relative;
  display: flex;
}

.background-color-chip {
  width: 100%;
}

.color-popover {
  position: absolute;
  z-index: 10;
  top: 40px;
  right: 0;
  display: grid;
  grid-template-columns: repeat(3, 32px);
  gap: 5px;
  width: max-content;
  border: 2px solid var(--pink);
  background: var(--white);
  box-shadow: 5px 5px 0 var(--pink);
  padding: 8px;
}

.mini-swatch {
  aspect-ratio: 1;
  min-height: 0;
  border: 1px solid var(--pink);
  outline: 0 solid var(--pink);
}

.mini-swatch:hover,
.active-mini-swatch {
  border-color: var(--active-pink);
  outline: 2px solid var(--active-pink);
  outline-offset: 1px;
}

.bottom-z-selector {
  display: grid;
  gap: 6px;
  text-transform: uppercase;
  border: 2px solid var(--pink);
  padding: 6px;
}

.bottom-z-rail {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 3px;
  border-top: 4px solid var(--pink);
  padding-top: 5px;
}

.z-depth {
  min-width: 0;
  min-height: 30px;
  padding: 0;
}

.active-z-depth {
  border-color: var(--active-pink);
  background: var(--active-pink);
  color: var(--white);
}

.modal-backdrop {
  position: fixed;
  inset: 0;
  z-index: 20;
  display: grid;
  place-items: center;
  background: rgb(255 255 255 / 72%);
  padding: 18px;
}

.blocking-operation-overlay {
  position: fixed;
  inset: 0;
  z-index: 60;
  display: grid;
  place-items: center;
  background: rgb(255 255 255 / 82%);
  padding: 18px;
}

.blocking-operation-panel {
  display: grid;
  gap: 14px;
  width: min(460px, 100%);
  border: 4px solid var(--active-pink);
  background: var(--white);
  box-shadow: 8px 8px 0 var(--active-pink);
  padding: 18px;
  text-align: center;
}

.blocking-operation-panel h2 {
  margin: 0;
  color: var(--active-pink);
  font-size: 16px;
  text-transform: uppercase;
}

.blocking-progress {
  text-align: left;
}

.page-confirm {
  align-items: start;
  padding-top: 96px;
  background: transparent;
  pointer-events: none;
}

.compact-modal {
  width: min(320px, 100%);
}

.modal-panel {
  display: grid;
  gap: 14px;
  width: min(720px, 100%);
  border: 4px solid var(--pink);
  background: var(--white);
  box-shadow: 8px 8px 0 var(--pink);
  padding: 18px;
  color: var(--pink);
}

.modal-panel h2,
.modal-panel p {
  margin: 0;
}

.modal-panel h2 {
  border-bottom: 3px solid var(--pink);
  font-size: 16px;
  text-transform: uppercase;
}

.modal-panel p,
.field-row {
  font-size: 13px;
  text-transform: uppercase;
}

.modal-note {
  border: 2px solid var(--pink);
  padding: 8px;
}

.field-row {
  display: grid;
  gap: 6px;
}

.field-row input,
.field-row select {
  min-height: 34px;
  border: 2px solid var(--pink);
  background: var(--white);
  color: var(--pink);
  padding: 4px 8px;
}

.modal-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  justify-content: flex-end;
}

.tab-row {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 8px;
}

.segmented-row {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 8px;
}

.export-frame-picker {
  display: grid;
  gap: 8px;
}

.partial-frame-list {
  display: flex;
  gap: 8px;
  max-width: 100%;
  overflow-x: auto;
  border: 2px solid var(--pink);
  padding: 8px;
}

.partial-frame-item {
  display: grid;
  gap: 5px;
  flex: 0 0 124px;
  border: 2px solid var(--pink);
  padding: 6px;
}

.partial-frame-item .frame-thumbnail {
  width: 104px;
}

@media (max-width: 1180px) {
  .app-shell {
    grid-template-columns: 150px minmax(0, 1fr) 260px;
    gap: 8px;
    padding: 8px;
  }

  .top-toolbar {
    grid-template-columns: 1fr;
  }

  .toolbar-actions {
    justify-content: flex-start;
  }

  .mode-actions button,
  .toolbar-actions button {
    min-width: 58px;
    padding: 0 6px;
  }
}
</file>

